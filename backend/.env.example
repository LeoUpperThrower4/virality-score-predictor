# ── Server ──
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ── TRIBE v2 ──
CACHE_DIR=./cache
LOAD_MODEL_ON_STARTUP=true

# ── Uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500

# ── HuggingFace (required for model download) ──
# Get your token at https://huggingface.co/settings/tokens
# You must accept the LLaMA 3.2 license at https://huggingface.co/meta-llama/Llama-3.2-3B
HF_TOKEN=your_huggingface_token_here
